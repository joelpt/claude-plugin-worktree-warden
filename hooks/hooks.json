{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/enforce_worktree_hook.py", "timeout": 10 }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/check_worktrees_hook.py", "timeout": 15 }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/check_worktrees_hook.py", "timeout": 15 }
        ]
      }
    ]
  }
}
